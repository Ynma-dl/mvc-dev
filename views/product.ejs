<!DOCTYPE html>
<html lang='fr'>
<head>
    <meta charset='utf-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <title><%= product.name %> - Détails</title>
    
    <!-- Polices et Icônes -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    
    <!-- Lien vers le fichier CSS -->
    <link rel='stylesheet' href='/css/product.css'>
</head>
<body>
    
    <!-- Header avec bouton retour et bouton panier -->
    <header class="page-header">
        <a href="javascript:history.back()" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
        <button class="cart-trigger" id="open-cart-btn">
            <i class="fa-solid fa-bag-shopping"></i>
            <span class="cart-badge">0</span>
        </button>
    </header>

    <main class="grid-product">
        
        <!-- SECTION GAUCHE : Images -->
        <div class="product-imgs-div">
            <div id="main-img">
                <img src="<%= product_imgs[0] %>" alt="Image principale">
            </div>
            <div id="other-imgs">
                <div class="other-img-div active">
                    <img src="<%= product_imgs[0] %>" alt="Miniature principale">
                </div>
                <% for (let i = 1; i < product_imgs.length; i++) { %>
                    <div class="other-img-div">
                        <img src="<%= product_imgs[i] %>" alt="Miniature">
                    </div>
                <% } %>
            </div>
        </div>

        <!-- SECTION DROITE : Informations -->
        <div class="product-info-div">

            <!-- En-tête du produit -->
            <div>
                <div id="is_dispo" class="badge dispo">
                    <i class="fa-solid fa-check"></i> En stock (<%= product.stock %> restants)
                </div>
                <h1 id="name"><%= product.name %></h1>
                <h2 id="price"><%= product.price %> FCFA</h2>
            </div>
            
            <p class="description"><%= product.description %></p>

            <!-- Options Dynamiques -->
            <% if (typeof optionsHTML !== 'undefined' && optionsHTML) { %>
                <div class="options-container">
                    <h4>Options disponibles :</h4>
                    <%- optionsHTML %>
                </div>
            <% } %>

            <!-- Contrôles d'Achat -->
            <div class="purchase-controls">
                <div class="quantity-control">
                    <button class="minus"><i class="fa-solid fa-minus"></i></button>
                    <span class="quantity">1</span>
                    <button class="plus"><i class="fa-solid fa-plus"></i></button>
                </div>

                <button 
                    class="add-to-cart"
                    data-id="<%= product.id %>"
                    data-name="<%= product.name %>"
                    data-price="<%= product.price %>"
                    data-image="<%= product_imgs[0] %>">
                    <i class="fa-solid fa-cart-plus"></i>
                    <span>Ajouter au panier</span>
                </button>
            </div>

            <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center;">
                <i class="fa-regular fa-clock"></i> Le vendeur répond généralement en moins de 5 minutes.
            </p>

            <!-- Cartes d'informations (Livraison, Paiement, Fonctionnement) -->
            <div class="info-cards-grid">
                
                <div class="info-card">
                    <h4><i class="fa-solid fa-truck-fast"></i> Options de livraison</h4>
                    <div class="location-div">
                        <span><i class="fa-solid fa-location-dot"></i> Abidjan (Standard)</span>
                        <strong>1500 FCFA</strong>
                    </div>
                    <div class="location-div">
                        <span><i class="fa-solid fa-map-location-dot"></i> Hors Abidjan</span>
                        <strong>Sur devis</strong>
                    </div>
                </div>

                <div class="info-card">
                    <h4><i class="fa-solid fa-shield-halved"></i> Paiement sécurisé</h4>
                    <p><i class="fa-solid fa-hand-holding-dollar" style="color: var(--accent-color);"></i> Vous ne payez qu'à la livraison.</p>
                    <p><i class="fa-solid fa-mobile-screen"></i> Paiement accepté par espèces ou Mobile Money.</p>
                </div>

            </div>
        </div>
    </main>

    <!-- NOUVEAU TIROIR DU PANIER (CART DRAWER) -->
    <!-- (Remplace ton ancien `<%- include('partials/cart-popup') %>`) -->
    <div class="cart-overlay" id="cart-overlay"></div>
    <aside class="cart-drawer" id="cart-drawer">
        <div class="cart-header">
            <h2>Votre Panier</h2>
            <button class="close-cart" id="close-cart-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <div class="cart-body" id="cart-items-container">
            <!-- Exemple d'un item stylisé (sera généré par ton JS) -->
            <p style="text-align:center; color: var(--text-muted); margin-top: 20px;">Votre panier est vide.</p>
        </div>

        <div class="cart-footer">
            <div class="cart-total">
                <span>Total :</span>
                <span id="cart-total-price">0 FCFA</span>
            </div>
            <button class="checkout-btn">Passer la commande via WhatsApp</button>
        </div>
    </aside>

    <!-- Scripts -->
    <script>
        // --- 1. GESTION DE LA GALERIE ---
        const mainImg = document.querySelector("#main-img img");
        const thumbs = document.querySelectorAll(".other-img-div");
        
        thumbs.forEach(thumb => {
            thumb.addEventListener("click", function() {
                // Changer l'image principale
                mainImg.style.opacity = '0.5';
                setTimeout(() => {
                    mainImg.src = this.querySelector('img').src;
                    mainImg.style.opacity = '1';
                }, 150);
                
                // Gérer la classe active
                thumbs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // --- 2. DISPONIBILITÉ ---
        const is_dispo = document.getElementById("is_dispo");
        const stock = <%= product.stock %>;
        if (stock <= 0) {
            is_dispo.innerHTML = '<i class="fa-solid fa-xmark"></i> Rupture de stock';
            is_dispo.className = 'badge rupture';
        }

        // --- 3. QUANTITÉ ---
        const quantityDisplay = document.querySelector(".quantity");
        document.querySelector(".plus").addEventListener("click", () => {
            quantityDisplay.textContent = Number(quantityDisplay.textContent) + 1;
        });
        document.querySelector(".minus").addEventListener("click", () => {
            if (Number(quantityDisplay.textContent) > 1) {
                quantityDisplay.textContent = Number(quantityDisplay.textContent) - 1;
            }
        });

        // --- 4. GESTION DE L'OUVERTURE DU PANIER (NOUVEAU) ---
        const cartOverlay = document.getElementById('cart-overlay');
        const cartDrawer = document.getElementById('cart-drawer');
        const openCartBtn = document.getElementById('open-cart-btn');
        const closeCartBtn = document.getElementById('close-cart-btn');

        function toggleCart() {
            cartOverlay.classList.toggle('active');
            cartDrawer.classList.toggle('active');
            // Empêche le scroll de la page quand le panier est ouvert
            document.body.style.overflow = cartDrawer.classList.contains('active') ? 'hidden' : 'auto';
        }

        openCartBtn.addEventListener('click', toggleCart);
        closeCartBtn.addEventListener('click', toggleCart);
        cartOverlay.addEventListener('click', toggleCart);

        // --- 5. AJOUT AU PANIER (Ton script existant adapté) ---
        const addCartBtn = document.querySelector(".add-to-cart");
        addCartBtn.addEventListener("click", async () => {
            if (stock <= 0) {
                alert("Produit en rupture de stock.");
                return;
            }

            // Récupère les options si existantes (logique à adapter selon tes besoins)
            const payload = {
                id: addCartBtn.dataset.id,
                name: addCartBtn.dataset.name,
                price: Number(addCartBtn.dataset.price),
                quantity: Number(quantityDisplay.textContent),
                image: addCartBtn.dataset.image
            };

            // Simule l'ajout et ouvre le tiroir panier
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                
                if (data.success) {
                    // Si tu as des fonctions pour rendre le panier, appelle-les ici
                    // renderCart(data.cart);
                    // updateCartSticker();
                    
                    // Ouvre le panier avec une petite animation pour confirmer l'ajout
                    toggleCart();
                }
            } catch (err) {
                console.error(err);
            }
        });
    </script>
