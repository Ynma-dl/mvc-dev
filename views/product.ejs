<!DOCTYPE html>
<html lang='fr'>
<head>
    <meta charset='utf-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <!-- Charger Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <title>Page produit</title>
    <link rel='stylesheet' href='/css/product.css'>
</head>
<body>
    
    <main class="main-content">

<!-- Icône retour -->
<div id="back-div">
   <a id="back-to-catalogue" href="javascript:history.back()">
      <p>
         <i class="fa-solid fa-arrow-left-long" id="back-to-catalogue"></i> 
         <span id="back-to-catalogue">Retour au catalogue</span>
      </p>
   </a>
</div>

        <section class="grid-product">
            <div class="product-imgs-div">

                <div id="main-img">
                    <img src="<%= product_imgs[0] %>" alt="Image principale du produit">
                </div>

                <div id="other-imgs">
                    <% for (let i = 1; i < product_imgs.length; i++) { %>
                        <div class="other-img-div">
                            <img src="<%= product_imgs[i] %>" alt="Image miniature du produit">
                        </div>
                    <% } %>
                </div>

            </div>

            <script>
                const mainImg = document.querySelector("#main-img img");

                document.querySelectorAll(".other-img-div img").forEach(img => {

                    img.addEventListener("click", () => {

                        const temp = mainImg.src;

                        mainImg.src = img.src;
                        img.src = temp;

                    });

                });
            </script>

            <div class="product-info-div">

                <div id="is_dispo"><i class="fa-solid fa-circle"></i> Disponible</div>

                <h1 id="name"><%= product.name %></h1>
                <h2 id="price"><%= product.price %> FCFA</h2>
                <h4 id="option">Options</h4>
                <div class="options-container">
                    <%- optionsHTML %>
                </div>

                <div class="quantity-control">

                <button class="minus">-</button>

                <span class="quantity">1</span>

                <button class="plus">+</button>

            </div>
                <h3>Description</h3>
                <p id="description-place"><%= product.description %></p>
                <p>stock: <%= product.stock %></p>
                <p>Catégorie: <%= product.category %></p>
                
                <button 
                    class="add-to-cart"
                    data-id="<%= product.id %>"
                    data-name="<%= product.name %>"
                    data-price="<%= product.price %>"
                    data-quantity=""
                    data-image="<%= product_imgs[0] %>">
                    
                    <i class="fa-solid fa-cart-arrow-down"></i>
                    <span>Add to cart</span>
                </button>
                <p id="comment"><i class="fa-regular fa-clock"></i> Reponse rapide du vendeur (souvent 5min)</p>
                <div id="shipping-info">
                    <h4><i class="fa-solid fa-truck"></i> Livraison</h4>

                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>
                    <div class="location-div">
                        <p class="location"><i class="fa-solid fa-location-dot"></i>Abidjan</p>
                        <p class="shipping-price">1500 FCFA</p>

                    </div>

            </div>

            <div class="payement-notice">

                <h4>instruction de paiement</h4>
                <p>paiement à la livraison <i class="fa-solid fa-circle-check"></i></p>
                <p>Livraison à vos frais</p>

            </div>

            <div id="how-working">
                <p><i class="fa-solid fa-clipboard"></i> Comment ça marche ?</p>
                <p><span class="step">1</span> Cliquez sur "Commander" pour passer au paiement</p>
                <p><span class="step">2</span> Le vendeur reçois une commande ur WhatsApp et vous livre</p>
                <p><span class="step">3</span> vous payer à la livraison avec vos moyen habituel(Mobile money, carte de crédit)</p>

            </div>

        </section>

    </main>

    <script>
        
        const is_dispo = document.getElementById("is_dispo");
        const optionGroups = document.querySelectorAll(".option-div");
        const selectedOptions = {};
        const addCartBtn = document.querySelector(".add-to-cart");
        const minus = document.querySelector(".minus");
        const plus = document.querySelector(".plus");
        const quantity = document.querySelector(".quantity");

        plus.addEventListener("click", () => {
            quantity.textContent = Number(quantity.textContent) + 1;
        });

        minus.addEventListener("click", () => {
            let value = Number(quantity.textContent);
            if (value > 1) {
                quantity.textContent = value - 1;
            }
        });

        // Gestion de la sélection des options (un choix actif par groupe)
        optionGroups.forEach(group => {
            group.addEventListener("click", (e) => {
                const option = e.target.closest(".option-item");
                if (!option) return;

                group.querySelectorAll(".option-item")
                    .forEach(item => item.classList.remove("active"));

                option.classList.add("active");

                selectedOptions[group.dataset.group] = option.dataset.option;
            });
        });

        // Un seul listener pour le clic "Ajouter au panier"
        addCartBtn.addEventListener("click", async () => {

            addCartBtn.classList.add('clicked');
            setTimeout(() => addCartBtn.classList.remove('clicked'), 150);

            if (Object.keys(selectedOptions).length !== optionGroups.length) {
                alert("Veuillez choisir toutes les options.");
                return;
            }

            const product = {
                id: addCartBtn.dataset.id,
                name: addCartBtn.dataset.name,
                price: Number(addCartBtn.dataset.price),
                options: selectedOptions,          // objet: { Pointure: "42", Couleur: "Noir" }
                quantity: Number(quantity.textContent),
                image: addCartBtn.dataset.image
            };

            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(product)
                });

                const data = await res.json();

                if (data.success) {
                    renderCart(data.cart);
                    updateCartSticker();
                }

            } catch (err) {
                console.error("Erreur ajout panier:", err);
            }
        });

        const stock = <%= product.stock %>;
        if (stock <= 0) {
            is_dispo.classList.add("false");
        }

    </script>

    <script src="/js/cart.js"></script>
    <script src="/js/carousel.js"></script>


</body>
</html>