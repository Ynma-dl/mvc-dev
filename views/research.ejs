<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    Résultats de recherche
    <% if (query) { %>
      pour "<%= query %>"
    <% } %>
  </title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/css/research.css">
</head>

<body>

  <!-- En-tête -->
  <header class="head-div">

    <!-- Icône retour dynamique -->
    <div id="back-div">
      <a href="http://localhost:5000" id="back-to-catalogue">
        <p>
          <i class="fa-solid fa-arrow-left-long"></i>
          <span>Retour au catalogue</span>
        </p>
      </a>
    </div>

    <!-- Moteur de recherche -->
    <div class="form-div">
      <form action="/search" method="GET" class="search-form">
        <input
          type="text"
          name="q"
          value="<%= query %>"
          placeholder="Rechercher un produit..."
        >
        <button type="submit">Chercher</button>
      </form>
    </div>

  </header>

  <!-- Section filtres -->
  <div class="filter-contain">
    <div class="filter-bar">

      <span class="style-gray">
        <!-- Affiche le nombre réel de résultats -->
        <span class="result-amount"><%= totalResults %></span>
        &nbsp;
        <%= totalResults > 1 ? 'résultats' : 'résultat' %>
      </span>

      <button class="button-filter">
        <span>Filtrer</span>
        &nbsp;
        <span class="number-result-amount">0</span>
      </button>

    </div>
  </div>

  <!-- Titre de la page -->
  <div class="research-title">
    <% if (query) { %>
      <h1>Résultats pour "<%= query %>"</h1>
    <% } %>
  </div>

<!-- Conteneur des produits -->
  <main class="search-results">

    <% if (message) { %>
      <p class="search-message">
        <%= message %>
      </p>
    <% } %>

    <% if (results && results.length > 0) { %>

      <%- productsHtml %>

    <% } else { %> <!-- Le "}" manquant a été rajouté ici ! -->

      <p class="search-message">Aucun produit trouvé.</p>

    <% } %>

  </main>

</body>

</html>